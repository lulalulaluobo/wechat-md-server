[Unit]
Description=wechat-md-server
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/wechat-md-server
EnvironmentFile=/opt/wechat-md-server/.env
ExecStart=/opt/wechat-md-server/.venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8765
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
